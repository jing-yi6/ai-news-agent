# X (Twitter) API Configuration
# 获取方式: https://developer.twitter.com/en/portal/dashboard
X_BEARER_TOKEN=your_bearer_token_here
X_USER_ID=your_twitter_user_id

# 可选: 用于生成中文摘要 (OpenAI API)
OPENAI_API_KEY=your_openai_api_key_here
# 可选: 自定义 OpenAI API 端点 (用于代理或兼容服务)
# OPENAI_BASE_URL=https://api.openai.com/v1
# 可选: 自定义模型名称
# OPENAI_MODEL=gpt-3.5-turbo

# 可选: 用于生成中文摘要 (OpenAI 兼容格式 API，如 Azure、本地模型等)
# OPENAI_COMPATIBLE_API_KEY=your_key_here
# OPENAI_COMPATIBLE_BASE_URL=https://your-compatible-api-endpoint.com/v1
# OPENAI_COMPATIBLE_MODEL=gpt-3.5-turbo

# 可选: 用于生成中文摘要 (Anthropic API)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
