# ============================================
# AI News Agent 配置
# ============================================

# --------------------------------------------
# 数据源配置
# --------------------------------------------
# 数据源类型：x (Twitter), mock 等（默认: x）
DATASOURCE=x

# 需要翻译的数据源（逗号分隔，默认空表示不翻译）
# 例如: x,twitter 表示 x 和 twitter 来源的内容会被翻译
# 留空或注释掉表示不翻译
TRANSLATE_SOURCES=

# X (Twitter) 账号配置（使用 twscrape，无需 API Key）
X_USERNAME=your_twitter_username

# 方式一：使用 Cookies（推荐）
# 注意：即使使用 cookies，也需要提供 X_USERNAME
# 从浏览器开发者工具复制 cookies 字符串
X_COOKIES=your_cookies_here

# 方式二：使用用户名密码登录
X_PASSWORD=your_twitter_password
X_EMAIL=your_email@example.com
X_EMAIL_PASSWORD=your_email_password

# 用户 ID（用于获取关注列表，可选）
X_USER_ID=your_twitter_user_id

# 请求速率限制（秒/次，必须 >= 0，默认 1.0）
X_RATE_LIMIT=1.0

# --------------------------------------------
# LLM 配置（可选，用于智能分类和摘要）
# --------------------------------------------
LLM_PROVIDER=openai          # openai 或 anthropic
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-3.5-turbo

# LLM 参数（可选）
# TEMPERATURE: 0.0 - 2.0，默认 0.3
# MAX_TOKENS: 必须 > 0，默认 1000
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000

# --------------------------------------------
# 日志配置（可选）
# --------------------------------------------
# LOG_DIR: 日志文件目录（默认 logs）
# 日志文件会自动命名: ai-news_YYYYMMDD_HHMMSS.log
LOG_DIR=logs
OUTPUT_DIR=output
# MIN_ENGAGEMENT: 最小互动数过滤（必须 >= 0，默认 0）
MIN_ENGAGEMENT=0
REQUIRE_AI_KEYWORDS=false
EXCLUDE_PROMOTIONAL=false
